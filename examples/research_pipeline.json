{
  "name": "research_pipeline",
  "version": "0.1.0",
  "description": "A simple research -> review -> write pipeline",
  "root": {
    "type": "sequence",
    "steps": [
      {
        "type": "agent",
        "agent": "researcher"
      },
      {
        "type": "condition",
        "expression": "output.needs_review",
        "true_branch": {
          "type": "loop",
          "max_iterations": 3,
          "body": {
            "type": "agent",
            "agent": "reviewer"
          }
        },
        "false_branch": {
          "type": "agent",
          "agent": "writer"
        }
      },
      {
        "type": "agent",
        "agent": "publisher"
      }
    ]
  }
}
